{
  "appId": "com.chibanilotfi.omnichat",
  "appName": "OmniChat",
  "webDir": ".",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f0f23",
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f0f23",
      "overlaysWebView": true
    }
  },
  "android": {
    "buildOptions": {
      "keystorePath": "omnichat.keystore",
      "keystoreAlias": "omnichat"
    }
  }
}